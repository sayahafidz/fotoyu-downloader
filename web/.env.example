# Domain where the web app will be hosted (e.g. fotoyu.example.com).
# Used by the bookmarklet so it redirects back to the correct URL.
NEXT_PUBLIC_APP_URL=https://fotoyu.example.com

# Dewatermark.ai API Configuration
# Get your API key from https://platform.dewatermark.ai/dashboard
DEWATERMARK_API_KEY=your_api_key_here
DEWATERMARK_API_URL=https://platform.dewatermark.ai/api/object_removal/v2/erase

# Optional: Rate limiting for watermark removal
MAX_WATERMARK_REQUESTS_PER_HOUR=100
